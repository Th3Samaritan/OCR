# Base URL of the Hermes FastAPI backend.
#
# Local dev: leave this pointing at "/api" — vite proxies /api -> http://localhost:8000
# (see vite.config.ts) so the browser never hits CORS.
#
# Production: set to the deployed API origin, e.g. https://api.hermes.example.com
VITE_API_URL=/api

# Optional: override the dev proxy target (defaults to http://localhost:8000).
VITE_API_PROXY_TARGET=http://localhost:8000
